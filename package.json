{
    "name": "playwright-pom",
    "version": "1.0.2",
    "description": "CLI generator for a Playwright JS/TS framework starter",
    "type": "module",
    "engines": {
        "node": ">=18"
    },
    "files": [
        "bin",
        "lib",
        "templates"
    ],
    "bin": {
        "playwright-pom": "./bin/index.js",
        "create-playwright-pom": "./bin/index.js"
    },
    "scripts": {
        "start": "node ./bin/index.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint ."
    },
    "keywords": [
        "playwright",
        "cli",
        "scaffold",
        "generator",
        "qa",
        "page-object-model"
    ],
    "author": "Gabriel Dali <https://www.linkedin.com/in/gabriel-dali-qa/>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/GabrielDali/pom-pw-js.git"
    },
    "devDependencies": {
        "@typescript-eslint/eslint-plugin": "^8.57.0",
        "@typescript-eslint/parser": "^8.57.0",
        "@vitest/coverage-v8": "^4.1.0",
        "eslint": "^10.0.3",
        "vitest": "^4.0.18"
    }
}
